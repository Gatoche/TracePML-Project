<Window x:Class="TracePML.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TracePML.Views"
        Title="TracePML" Width="980" Height="680"
        MinWidth="820" MinHeight="500"
        FontFamily="Tahoma" FontSize="14"
        Closing="Window_Closing">

    <TabControl>

        <!-- ========================================================= -->
        <!-- Onglet 1 : gTracePML (reproduction fidèle de la fenêtre)  -->
        <!-- ========================================================= -->
        <TabItem Header="gTracePML">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- lblSizeLog -->
                    <RowDefinition Height="Auto"/>  <!-- Mode debug + Mode test -->
                    <RowDefinition Height="Auto"/>  <!-- Emission checkboxes -->
                    <RowDefinition Height="Auto"/>  <!-- Reception checkboxes -->
                    <RowDefinition Height="Auto"/>  <!-- Label FLUX PharmaML -->
                    <RowDefinition Height="*"/>     <!-- mmoPML -->
                    <RowDefinition Height="Auto"/>  <!-- Label NOTIFICATIONS + btn Test Notify -->
                    <RowDefinition Height="200"/>   <!-- mmoNotify -->
                </Grid.RowDefinitions>

                <!-- lblSizeLog (centré en haut) -->
                <TextBlock Grid.Row="0" Text="{Binding LogFileSize}" HorizontalAlignment="Center"
                           FontSize="11" Margin="0,2,0,4"/>

                <!-- Mode debogage (gauche) + Mode test / Winpharma / Local / Parse (droite) -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="Mode debogage"
                              IsChecked="{Binding IsDebugMode}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="Mode test" IsChecked="{Binding IsTestMode}" Margin="0,0,15,0"/>
                        <RadioButton Content="Winpharma" GroupName="TestSource"
                                     IsChecked="{Binding IsLocalTest, Converter={StaticResource InverseBoolConverter}}"
                                     IsEnabled="{Binding IsTestMode}" Margin="0,0,10,0"/>
                        <RadioButton Content="Local" GroupName="TestSource"
                                     IsChecked="{Binding IsLocalTest}"
                                     IsEnabled="{Binding IsTestMode}" Margin="0,0,15,0"/>
                        <Button Content="Parse" Command="{Binding ParseCommand}"
                                IsEnabled="{Binding IsTestMode}" Width="80" Height="25"/>
                    </StackPanel>
                </Grid>

                <!-- Emission -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Emission" FontWeight="Bold" Width="75" VerticalAlignment="Center"/>
                    <CheckBox Content="COMMANDE" IsChecked="{Binding ShowOrder}" Margin="0,0,12,0"/>
                    <CheckBox Content="REQ_INFO_PRODUIT" IsChecked="{Binding ShowRequestInfoProduct}" Margin="0,0,12,0"/>
                    <CheckBox Content="ACQUITTEMENT" IsChecked="{Binding ShowAcknowledgement}" Margin="0,0,12,0"/>
                    <CheckBox Content="VIDAGE" IsChecked="{Binding ShowEmptying}"/>
                </StackPanel>

                <!-- Réception -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Reception" FontWeight="Bold" Width="75" VerticalAlignment="Center"/>
                    <CheckBox Content="REP_COMMANDE" IsChecked="{Binding ShowOrderResponse}" Margin="0,0,12,0"/>
                    <CheckBox Content="REP_INFO_PRODUIT" IsChecked="{Binding ShowDispoInfoResponse}" Margin="0,0,12,0"/>
                    <CheckBox Content="BON_LIVRAISON" IsChecked="{Binding ShowDeliveryResponse}" Margin="0,0,12,0"/>
                    <CheckBox Content="ERREUR" IsChecked="{Binding ShowResponseError}" Margin="0,0,12,0"/>
                    <CheckBox Content="FIN_SERVICE" IsChecked="{Binding ShowServiceEnd}"/>
                </StackPanel>

                <!-- Label FLUX PharmaML -->
                <TextBlock Grid.Row="4" Text="FLUX PharmaML" FontWeight="Bold" Margin="0,0,0,4"/>

                <!-- mmoPML -->
                <TextBox Grid.Row="5"
                         Text="{Binding PmlLogText, Mode=OneWay}"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Courier New" FontSize="12"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         Margin="0,0,0,6"/>

                <!-- NOTIFICATIONS + Test Notify -->
                <DockPanel Grid.Row="6" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="Test Notify"
                            Command="{Binding TestNotifyCommand}" Width="90" Height="25"/>
                    <TextBlock Text="NOTIFICATIONS" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- mmoNotify -->
                <TextBox Grid.Row="7"
                         Text="{Binding NotificationLogText, Mode=OneWay}"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Courier New" FontSize="12"
                         AcceptsReturn="True" TextWrapping="NoWrap"/>
            </Grid>
        </TabItem>

        <!-- ========================================================= -->
        <!-- Onglet 2 : Notify (reproduction fidèle de la fenêtre)     -->
        <!-- ========================================================= -->
        <TabItem Header="Notify">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Boutons Test Pop-Up, Effacer -->
                    <RowDefinition Height="Auto"/>  <!-- Panel aperçu toast (1200x120) -->
                    <RowDefinition Height="Auto"/>  <!-- RadioButtons statut -->
                    <RowDefinition Height="*"/>     <!-- textBox1 (log messages reçus) -->
                </Grid.RowDefinitions>

                <!-- Rangée boutons (comme frmMain de Notify) -->
                <StackPanel x:Name="NotifyButtonsPanel" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Test Pop-Up" Command="{Binding ShowPreviewToastCommand}"
                            Width="120" Height="30" Margin="0,0,15,0"/>
                    <Button Content="Effacer" Command="{Binding ClearToastLogCommand}"
                            Width="90" Height="30"/>
                </StackPanel>

                <!-- Aperçu toast (composant ToastBanner réutilisable) -->
                <views:ToastBanner x:Name="PreviewBanner" Grid.Row="1"
                                   HorizontalAlignment="Left" Margin="0,0,0,10"/>

                <!-- RadioButtons (= radioButton1/2/3 de Notify) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton Content="Commande validee" GroupName="ToastStatus"
                                 IsChecked="{Binding PreviewConfirmed}" Margin="0,0,30,0"/>
                    <RadioButton Content="Commande partielle" GroupName="ToastStatus"
                                 IsChecked="{Binding PreviewModified}" Margin="0,0,30,0"/>
                    <RadioButton Content="Commande annulee" GroupName="ToastStatus"
                                 IsChecked="{Binding PreviewCancelled}"/>
                </StackPanel>

                <!-- textBox1 (= log des messages reçus de Notify) -->
                <TextBox Grid.Row="3"
                         Text="{Binding ToastLogText, Mode=OneWay}"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Tahoma" FontSize="12"
                         AcceptsReturn="True" TextWrapping="NoWrap"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
